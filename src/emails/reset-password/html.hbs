<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Your Password</title>
    <link href="https://api.fontshare.com/v2/css?f[]=satoshi@700,500,400&display=swap" rel="stylesheet">
</head>
<body style="margin: 0; padding: 0; font-family: 'Satoshi', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; background-color: #f5f5f5;">
    <table role="presentation" style="width: 100%; border-collapse: collapse;">
        <tr>
            <td style="padding: 40px 20px;">
                <table role="presentation" style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
                    <!-- Header Image -->
                    <tr>
                        <td style="padding: 0;">
                            <img src="https://usehive.s3.eu-north-1.amazonaws.com/hive-assets/header1x.png" alt="Hive" style="width: 100%; height: auto; display: block;">
                        </td>
                    </tr>

                    <!-- Content -->
                    <tr>
                        <td style="padding: 40px;">
                            <h1 style="margin: 0 0 20px; font-size: 28px; color: #333333; font-weight: 700;">Reset Your Password</h1>

                            <p style="margin: 0 0 16px; font-size: 16px; line-height: 1.6; color: #555555; font-weight: 400;">
                                Hi {{name}},
                            </p>

                            <p style="margin: 0 0 24px; font-size: 16px; line-height: 1.6; color: #555555; font-weight: 400;">
                                We received a request to reset your password. Click the button below to choose a new password:
                            </p>

                            <!-- CTA Button -->
                            <table role="presentation" style="margin: 30px 0; width: 100%;">
                                <tr>
                                    <td style="text-align: center;">
                                        <a href="{{resetLink}}" style="display: inline-block; padding: 14px 32px; background-color: #feb307; color: #000000; text-decoration: none; border-radius: 6px; font-weight: 700; font-size: 16px; font-family: 'Satoshi', sans-serif;">Reset Password</a>
                                    </td>
                                </tr>
                            </table>

                            <p style="margin: 24px 0 16px; font-size: 16px; line-height: 1.6; color: #555555; font-weight: 400;">
                                This link will expire in <strong style="font-weight: 700;">{{expiryMinutes}} minutes</strong>.
                            </p>

                            <p style="margin: 0 0 24px; font-size: 16px; line-height: 1.6; color: #555555; font-weight: 400;">
                                If you didn't request a password reset, please ignore this email. Your password will remain unchanged.
                            </p>

                            <!-- Security Info Box -->
                            <div style="background-color: #fff9e6; border-left: 4px solid #f9c606; padding: 16px; margin: 24px 0; border-radius: 4px;">
                                <p style="margin: 0; font-size: 14px; font-weight: 700; color: #333333;">
                                    Security Tip
                                </p>
                                <p style="margin: 8px 0 0; font-size: 14px; line-height: 1.5; color: #666666; font-weight: 400;">
                                    Never share this link with anyone. Hive will never ask you for your password via email.
                                </p>
                            </div>

                            <p style="margin: 24px 0 0; font-size: 16px; line-height: 1.6; color: #555555; font-weight: 400;">
                                Best regards,<br>
                                <strong style="font-weight: 700;">The Hive Team</strong>
                            </p>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td style="background-color: #f9f9f9; padding: 30px 40px; text-align: center; border-top: 1px solid #eeeeee;">
                            <p style="margin: 0 0 8px; font-size: 14px; color: #888888; font-weight: 400;">
                                This is an automated security message. Please do not reply to this email.
                            </p>
                            <p style="margin: 0 0 8px; font-size: 14px; color: #888888; font-weight: 400;">
                                &copy; 2026 Hive. All rights reserved.
                            </p>
                            <p style="margin: 0; font-size: 14px; color: #888888; font-weight: 400;">
                                <a href="#" style="color: #f9c606; text-decoration: none; font-weight: 500;">Privacy Policy</a> |
                                <a href="#" style="color: #f9c606; text-decoration: none; font-weight: 500;">Security</a>
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
